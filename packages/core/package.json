{
  "name": "@configenvy/core",
  "version": "0.1.4",
  "description": "Core scanners and diagnostics for configenvy.",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sonsriver4815/configenvy.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/sonsriver4815/configenvy/issues"
  },
  "homepage": "https://github.com/sonsriver4815/configenvy#readme",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -b tsconfig.json --clean && tsup src/index.ts src/reporters.ts src/types.ts --format esm --clean && tsc -p tsconfig.json --emitDeclarationOnly"
  },
  "dependencies": {
    "typescript": "5.9.3"
  },
  "keywords": [
    "env",
    "dotenv",
    "configuration",
    "developer-tools"
  ],
  "license": "MIT"
}
