{
  "name": "configenvy-repo",
  "private": true,
  "version": "0.1.7",
  "description": "Find missing, unused, undocumented, and risky environment variables before your users hit setup errors.",
  "type": "module",
  "packageManager": "npm@11.12.1",
  "engines": {
    "node": ">=18",
    "npm": ">=9"
  },
  "workspaces": [
    "packages/core",
    "packages/cli"
  ],
  "scripts": {
    "build": "npm run build -w @configenvy/core && npm run build -w configenvy",
    "test": "vitest run",
    "lint": "tsc -b --pretty false",
    "check": "npm run lint && npm test && npm run build",
    "pack:check": "npm pack --dry-run --json -w @configenvy/core && npm pack --dry-run --json -w configenvy"
  },
  "keywords": [
    "env",
    "dotenv",
    "developer-tools",
    "cli",
    "documentation"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
